  "schema": "public",
  "timeout_seconds": 300,
  "headers": {
    "X-Client-Info": "AccretionDisk-Supabase/1.0"
  },
  "auth": {
    "persist_session": true,
    "auto_refresh_token": true,
    "default_email_redirect_to": ""
